# ===================================
# FastAPI & Application Settings
# ===================================
FASTAPI_ENV=development
SECRET_KEY=your-super-secret-key-change-in-production
API_KEY=your-api-key
DEBUG=true

# ===================================
# OpenAI / LLM Configuration
# ===================================
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4
OPENAI_TEMPERATURE=0.7

# ===================================
# Slack Integration
# ===================================
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_SIGNING_SECRET=your-slack-signing-secret
SLACK_WORKSPACE_ID=T0123456789

# ===================================
# Gmail / Email Integration
# ===================================
GMAIL_CREDENTIALS_JSON=./credentials/gmail_credentials.json
GMAIL_SCOPES=https://www.googleapis.com/auth/gmail.readonly

# ===================================
# Google Drive Integration
# ===================================
GOOGLE_DRIVE_CREDENTIALS_JSON=./credentials/google_drive_credentials.json
GOOGLE_DRIVE_SCOPES=https://www.googleapis.com/auth/drive.readonly

# ===================================
# Trello Integration
# ===================================
TRELLO_API_KEY=your-trello-api-key
TRELLO_API_TOKEN=your-trello-api-token
TRELLO_BOARD_ID=your-trello-board-id

# ===================================
# Asana Integration (Optional)
# ===================================
ASANA_API_TOKEN=your-asana-api-token
ASANA_WORKSPACE_ID=your-asana-workspace-id

# ===================================
# Notion Integration
# ===================================
NOTION_API_KEY=notionclient-your-notion-api-key
NOTION_DATABASE_ID=your-notion-database-id

# ===================================
# Database Configuration
# ===================================
DATABASE_URL=postgresql://autopilot:password@localhost:5432/autopilot_db
DATABASE_ECHO=false
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# ===================================
# Redis Configuration
# ===================================
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=
REDIS_EXPIRY_TIME=3600

# ===================================
# Qdrant Vector Database
# ===================================
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=autopilot_vectors
QDRANT_EMBEDDING_MODEL=text-embedding-3-small

# ===================================
# Celery Task Queue
# ===================================
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_TASK_SOFT_TIME_LIMIT=300
CELERY_TASK_TIME_LIMIT=600

# ===================================
# Monitoring & Observability
# ===================================
OPENTELEMETRY_ENABLED=true
OPENTELEMETRY_EXPORTER=jaeger
JAEGER_AGENT_HOST=localhost
JAEGER_AGENT_PORT=6831
JAEGER_SERVICE_NAME=autopilot-backend

PHOENIX_ENABLED=true
PHOENIX_URL=http://localhost:6006

# ===================================
# Logging Configuration
# ===================================
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=./logs/autopilot.log

# ===================================
# Server Configuration
# ===================================
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
SERVER_WORKERS=4

# ===================================
# Feature Flags
# ===================================
ENABLE_MEETING_SUMMARIZATION=true
ENABLE_TASK_ASSIGNMENT=true
ENABLE_DATA_CLEANING=true
ENABLE_REPORT_GENERATION=true
ENABLE_SLACK_INTEGRATION=true
ENABLE_EMAIL_INTEGRATION=true

# ===================================
# Rate Limiting
# ===================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# ===================================
# Security
# ===================================
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ORIGINS=http://localhost:3000
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=60

# ===================================
# AI Model Configuration
# ===================================
SUMMARIZATION_MODEL=gpt-4
SUMMARIZATION_MAX_TOKENS=1000
TASK_EXTRACTION_MODEL=gpt-4
TASK_EXTRACTION_MAX_TOKENS=500

# ===================================
# Whisper Configuration (Transcription)
# ===================================
WHISPER_MODEL=base
WHISPER_LANGUAGE=en

# ===================================
# Webhook Configuration
# ===================================
SLACK_WEBHOOK_ENABLED=true
GMAIL_WEBHOOK_ENABLED=false
WEBHOOK_TIMEOUT=30

# ===================================
# Development / Testing
# ===================================
PYTEST_ASYNCIO_MODE=auto
TESTING=false
